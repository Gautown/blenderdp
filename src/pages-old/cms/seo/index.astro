---
import MainLayout from '../../../layouts/MainLayout.astro';
---

<MainLayout title="SEO设置 - Pages CMS" description="优化搜索引擎排名">
  <div class="cms-page">
    <header class="page-header">
      <h1>SEO设置</h1>
      <p>优化网站搜索引擎排名</p>
    </header>
    
    <div class="seo-settings">
      <div class="setting-section">
        <h2>全局SEO设置</h2>
        <div class="setting-form">
          <div class="form-group">
            <label for="siteTitle">网站标题</label>
            <input type="text" id="siteTitle" placeholder="输入网站标题" />
          </div>
          
          <div class="form-group">
            <label for="siteDescription">网站描述</label>
            <textarea id="siteDescription" placeholder="输入网站描述" rows="3"></textarea>
          </div>
          
          <div class="form-group">
            <label for="siteKeywords">网站关键词</label>
            <input type="text" id="siteKeywords" placeholder="输入关键词，用逗号分隔" />
          </div>
          
          <div class="form-group">
            <label for="ogImage">OpenGraph图片</label>
            <div class="image-upload">
              <input type="file" id="ogImage" accept="image/*" />
              <label for="ogImage" class="upload-btn">选择图片</label>
            </div>
          </div>
        </div>
      </div>
      
      <div class="setting-section">
        <h2>社交媒体设置</h2>
        <div class="setting-form">
          <div class="form-group">
            <label for="twitterHandle">Twitter账号</label>
            <input type="text" id="twitterHandle" placeholder="@username" />
          </div>
          
          <div class="form-group">
            <label for="facebookAppId">Facebook App ID</label>
            <input type="text" id="facebookAppId" placeholder="输入App ID" />
          </div>
        </div>
      </div>
      
      <div class="setting-section">
        <h2>搜索引擎验证</h2>
        <div class="setting-form">
          <div class="form-group">
            <label for="googleVerification">Google验证码</label>
            <input type="text" id="googleVerification" placeholder="输入验证码" />
          </div>
          
          <div class="form-group">
            <label for="bingVerification">Bing验证码</label>
            <input type="text" id="bingVerification" placeholder="输入验证码" />
          </div>
        </div>
      </div>
      
      <div class="setting-actions">
        <button class="btn-primary">保存设置</button>
        <button class="btn-secondary">重置</button>
      </div>
    </div>
  </div>
  
  <style>
    .cms-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }
    
    .page-header {
      margin-bottom: 2rem;
    }
    
    .page-header h1 {
      font-size: 2rem;
      color: #333;
      margin-bottom: 0.5rem;
    }
    
    .page-header p {
      color: #666;
      margin-bottom: 1rem;
    }
    
    .seo-settings {
      background: white;
      border: 1px solid #e9ecef;
      border-radius: 8px;
    }
    
    .setting-section {
      padding: 2rem;
      border-bottom: 1px solid #e9ecef;
    }
    
    .setting-section:last-child {
      border-bottom: none;
    }
    
    .setting-section h2 {
      margin: 0 0 1.5rem 0;
      color: #333;
      font-size: 1.5rem;
    }
    
    .setting-form {
      max-width: 600px;
    }
    
    .form-group {
      margin-bottom: 1.5rem;
    }
    
    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 600;
      color: #495057;
    }
    
    .form-group input,
    .form-group textarea {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-size: 1rem;
    }
    
    .form-group textarea {
      resize: vertical;
      min-height: 100px;
    }
    
    .image-upload {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    
    .upload-btn {
      background: #6c757d;
      color: white;
      padding: 0.5rem 1rem;
      border-radius: 4px;
      cursor: pointer;
      display: inline-block;
    }
    
    .upload-btn:hover {
      background: #5a6268;
    }
    
    .setting-actions {
      padding: 2rem;
      text-align: right;
      border-top: 1px solid #e9ecef;
    }
    
    .btn-primary {
      background: #007bff;
      color: white;
      border: none;
      padding: 0.75rem 1.5rem;
      border-radius: 4px;
      cursor: pointer;
      font-size: 1rem;
      margin-right: 1rem;
    }
    
    .btn-primary:hover {
      background: #0056b3;
    }
    
    .btn-secondary {
      background: #6c757d;
      color: white;
      border: none;
      padding: 0.75rem 1.5rem;
      border-radius: 4px;
      cursor: pointer;
      font-size: 1rem;
    }
    
    .btn-secondary:hover {
      background: #5a6268;
    }
  </style>
</MainLayout>